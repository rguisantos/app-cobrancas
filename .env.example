# ============================================================================
# CONFIGURAÇÕES DE AMBIENTE - DIAMOND SISTEMAS
# Copie este arquivo para .env e ajuste os valores
# ============================================================================

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------
# URL da API em produção
EXPO_PUBLIC_API_URL=https://api.suaempresa.com.br

# URL da API em homologação (descomente para usar)
# EXPO_PUBLIC_API_URL=https://homolog.suaempresa.com.br

# ----------------------------------------------------------------------------
# MODO DESENVOLVIMENTO
# ----------------------------------------------------------------------------
# Usar mock de dados (true para desenvolvimento, false para produção)
EXPO_PUBLIC_USE_MOCK=true

# Modo debug (true para desenvolvimento, false para produção)
EXPO_PUBLIC_DEBUG=true

# ----------------------------------------------------------------------------
# INFORMAÇÕES DO APP
# ----------------------------------------------------------------------------
# Nome do aplicativo (exibido na interface)
EXPO_PUBLIC_APP_NAME=Diamond Cobranças

# Versão do aplicativo
EXPO_PUBLIC_APP_VERSION=1.0.0

# ----------------------------------------------------------------------------
# SINCRONIZAÇÃO
# ----------------------------------------------------------------------------
# Intervalo de sincronização automática (minutos)
EXPO_PUBLIC_SYNC_INTERVAL=15

# Máximo de registros por sincronização
EXPO_PUBLIC_MAX_RECORDS_PER_SYNC=100

# Timeout das requisições (milissegundos)
EXPO_PUBLIC_TIMEOUT=30000

# ----------------------------------------------------------------------------
# WHITE LABEL - CORES DA MARCA
# ----------------------------------------------------------------------------
# Cor primária (hex sem #)
EXPO_PUBLIC_PRIMARY_COLOR=2563EB

# Cor secundária (hex sem #)
EXPO_PUBLIC_SECONDARY_COLOR=16A34A

# Cor de destaque (hex sem #)
EXPO_PUBLIC_ACCENT_COLOR=DC2626

# ----------------------------------------------------------------------------
# CONFIGURAÇÕES DE BUILD
# ----------------------------------------------------------------------------
# ID do projeto Expo Updates
EXPO_PUBLIC_UPDATES_URL=https://u.expo.dev/your-project-id

# Bundle identifier iOS
EXPO_PUBLIC_IOS_BUNDLE_ID=com.suaempresa.cobrancas

# Package name Android
EXPO_PUBLIC_ANDROID_PACKAGE=com.suaempresa.cobrancas