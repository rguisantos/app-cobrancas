# ============================================================================
# CONFIGURAÇÕES DE AMBIENTE - APP COBRANÇAS
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente
# ============================================================================

# ----------------------------------------------------------------------------
# API BACKEND
# ----------------------------------------------------------------------------
# URL da API para sincronização (deixe vazio para modo offline)
EXPO_PUBLIC_API_URL=

# URL alternativa para homologação
# EXPO_PUBLIC_API_URL=https://homolog.seuservidor.com.br

# URL para produção
# EXPO_PUBLIC_API_URL=https://api.seuservidor.com.br

# ----------------------------------------------------------------------------
# MODO DE DESENVOLVIMENTO
# ----------------------------------------------------------------------------
# Usar dados mock (true = não conecta na API, usa dados locais)
EXPO_PUBLIC_USE_MOCK=true

# Modo debug (logs detalhados no console)
EXPO_PUBLIC_DEBUG=true

# ----------------------------------------------------------------------------
# CREDENCIAIS MOCK (apenas para desenvolvimento/testes)
# ----------------------------------------------------------------------------
# ⚠️ NUNCA use credenciais reais de produção como mock!
# ⚠️ Estes valores são usados APENAS quando USE_MOCK=true.
# ⚠️ Em produção, defina USE_MOCK=false e remova estas variáveis.

# Email do usuário mock para login
EXPO_PUBLIC_MOCK_EMAIL=mock-user@exemplo.com

# Senha do usuário mock para login
EXPO_PUBLIC_MOCK_PASSWORD=mock_password_dev_only

# Tipo de permissão do usuário mock: Administrador, Secretario, AcessoControlado
EXPO_PUBLIC_MOCK_PERMISSION=Administrador

# ----------------------------------------------------------------------------
# INFORMAÇÕES DO APP
# ----------------------------------------------------------------------------
# Nome exibido na interface
EXPO_PUBLIC_APP_NAME=App Cobranças

# Versão do aplicativo (usado para display, não para build)
EXPO_PUBLIC_APP_VERSION=1.0.0

# Nome da empresa (exibido em relatórios e sobre)
EXPO_PUBLIC_COMPANY_NAME=Sua Empresa

# Email de suporte
EXPO_PUBLIC_SUPPORT_EMAIL=suporte@suempresa.com.br

# ----------------------------------------------------------------------------
# SINCRONIZAÇÃO
# ----------------------------------------------------------------------------
# Intervalo de sincronização automática em minutos
EXPO_PUBLIC_SYNC_INTERVAL=15

# Máximo de registros enviados por requisição de sync
EXPO_PUBLIC_MAX_RECORDS_PER_SYNC=100

# Timeout das requisições HTTP em milissegundos
EXPO_PUBLIC_TIMEOUT=30000

# Sincronizar ao abrir o app
EXPO_PUBLIC_SYNC_ON_START=true

# Sincronizar ao voltar para o app (background -> foreground)
EXPO_PUBLIC_SYNC_ON_RESUME=true

# ----------------------------------------------------------------------------
# WHITE LABEL - IDENTIDADE VISUAL
# ----------------------------------------------------------------------------
# Cor primária em HEX sem o # (azul padrão)
EXPO_PUBLIC_PRIMARY_COLOR=2563EB

# Cor secundária em HEX sem o # (verde padrão)
EXPO_PUBLIC_SECONDARY_COLOR=16A34A

# Cor de alerta/erro em HEX sem o # (vermelho padrão)
EXPO_PUBLIC_ACCENT_COLOR=DC2626

# Cor de sucesso em HEX sem o # (verde)
EXPO_PUBLIC_SUCCESS_COLOR=22C55E

# Cor de aviso em HEX sem o # (amarelo)
EXPO_PUBLIC_WARNING_COLOR=F59E0B

# ----------------------------------------------------------------------------
# CONFIGURAÇÕES DE BUILD (EAS)
# ----------------------------------------------------------------------------
# ID do projeto no Expo (obtido em expo.dev)
# EXPO_PUBLIC_PROJECT_ID=seu-project-id

# URL para updates OTA (preenchido automaticamente pelo EAS)
# EXPO_PUBLIC_UPDATES_URL=https://u.expo.dev/seu-project-id

# ----------------------------------------------------------------------------
# CONFIGURAÇÕES ESPECÍFICAS
# ----------------------------------------------------------------------------
# Valor padrão da ficha/partida (usado em novas locações)
EXPO_PUBLIC_DEFAULT_FICHA_VALUE=3.00

# Percentual padrão da empresa (usado em novas locações)
EXPO_PUBLIC_DEFAULT_PERCENTUAL_EMPRESA=50

# Dias para alertar cobranças atrasadas
EXPO_PUBLIC_DIAS_ATRASO_ALERTA=7

# ----------------------------------------------------------------------------
# LOGGING E MONITORAMENTO
# ----------------------------------------------------------------------------
# Nível de log: debug, info, warn, error
EXPO_PUBLIC_LOG_LEVEL=debug

# Habilitar logs de SQL (apenas para desenvolvimento)
EXPO_PUBLIC_LOG_SQL=false

# ============================================================================
# INSTRUÇÕES
# ============================================================================
# 
# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Ajuste os valores conforme seu ambiente:
#    - Desenvolvimento: USE_MOCK=true, DEBUG=true
#    - Homologação: USE_MOCK=false, API_URL=hml, DEBUG=true
#    - Produção: USE_MOCK=false, DEBUG=false
#
# 3. Reinicie o app após alterar variáveis:
#    npm start -- --clear
#
# ============================================================================
