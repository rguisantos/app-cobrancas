{
  "expo": {
    "name": "App Cobranças",
    "slug": "app-cobrancas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.suaempresa.cobrancas",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Este app precisa de acesso à câmera para escanear códigos.",
        "NSLocationWhenInUseUsageDescription": "Este app precisa de acesso à localização para mostrar endereços no mapa."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.suaempresa.cobrancas",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-updates",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "updates": {},
    "runtimeVersion": "1.0.0",
    "extra": {
      "API_URL": "https://api.suaempresa.com.br",
      "USE_MOCK": "true",
      "APP_VERSION": "1.0.0",
      "APP_NAME": "App Cobranças",
      "DEBUG": "true",
      "SYNC_INTERVAL": "15",
      "MAX_RECORDS_PER_SYNC": "100",
      "TIMEOUT": "30000",
      "eas": {
        "projectId": "591a2817-9aed-4a61-81a0-588489597cb6"
      }
    },
    "owner": "rguisantoss"
  }
}
